# Optional raw-env server settings for local development.
# Named-instance commands (`openboard add/start/attach`) inject their own
# workspace, port, DB, and token values, so most testers do not need this file.

# Adapter port for `npm run dev:server` or other direct server launches.
OPENBOARD_PORT=4097

# Required for raw server launches. Must point at an existing directory.
BOARD_WORKSPACE=/path/to/your/repo

# Optional SQLite DB path for raw server launches. Keep runtime DBs out of git.
OPENBOARD_DB=/tmp/openboard/board.sqlite

# Optional spawned OpenCode server port. Leave unset to auto-pick a free port.
# OPENBOARD_OPENCODE_PORT=4096

# Unsafe escape hatch: allow task/terminal directories outside BOARD_WORKSPACE.
# OPENBOARD_ALLOW_EXTERNAL_DIRECTORIES=false

# Optional fixed API token for scripts/CI. Leave unset for random per-process tokens.
# OPENBOARD_API_TOKEN=

# Optional editor template for View Diff `e`; supports {file} and {line}.
# OPENBOARD_EDITOR="code -g {file}:{line}"
