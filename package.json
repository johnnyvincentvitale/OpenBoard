{
  "name": "opencode-board",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Local Devin-style Kanban command center for OpenCode sessions",
  "main": "electron/main.cjs",
  "scripts": {
    "test": "vitest run --exclude '**/test/integration/**'",
    "test:integration": "vitest run test/integration",
    "test:coverage": "vitest run --exclude '**/test/integration/**' --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev": "vite",
    "dev:server": "tsx src/server/serve.ts",
    "build": "vite build",
    "start": "tsx src/server/serve.ts",
    "build:web": "vite build",
    "build:server": "esbuild src/server/serve.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/server/serve.mjs --external:better-sqlite3 --external:electron --banner:js=\"import{createRequire as __ocbCreateRequire}from'module';const require=__ocbCreateRequire(import.meta.url);\"",
    "build:app": "npm run build:web && npm run build:server",
    "electron": "npm run build:web && electron .",
    "electron:pack": "npm run build:app && electron-builder --dir && npm rebuild better-sqlite3",
    "prepare": "husky"
  },
  "build": {
    "appId": "com.johnnyvitale.opencode-board",
    "productName": "opencode-board",
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "mac": {
      "target": "dir",
      "identity": null
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hono/node-server": "^2.0.6",
    "@opencode-ai/sdk": "^1.17.13",
    "better-sqlite3": "^12.11.1",
    "hono": "^4.12.27",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
