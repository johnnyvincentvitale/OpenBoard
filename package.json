{
  "name": "openboard",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Local Devin-style Kanban command center for OpenCode sessions",
  "license": "MIT",
  "bin": {
    "openboard": "dist/cli/openboard.mjs"
  },
  "scripts": {
    "verify": "npm run typecheck && npm test && npm run test:integration && npm run build:app",
    "test": "vitest run --exclude '**/test/integration/**'",
    "test:integration": "vitest run test/integration",
    "test:coverage": "vitest run --exclude '**/test/integration/**' --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev:server": "tsx src/server/serve.ts",
    "build": "npm run build:app",
    "start": "tsx src/server/serve.ts",
    "build:server": "esbuild src/server/serve.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/server/serve.mjs --external:better-sqlite3 --external:node-pty --banner:js=\"import{createRequire as __ocbCreateRequire}from'module';const require=__ocbCreateRequire(import.meta.url);\"",
    "build:mcp": "esbuild src/mcp/server.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/mcp/server.mjs",
    "build:cli": "esbuild src/cli/openboard.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/cli/openboard.mjs",
    "build:tui": "npm run build:tui:renderer && npm run build:tui:launcher",
    "build:tui:renderer": "esbuild src/tui/index.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/tui/index.mjs --external:@opentui/core",
    "build:tui:launcher": "esbuild src/tui/launcher.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/tui/launcher.mjs",
    "build:app": "npm run build:server && npm run build:mcp && npm run build:tui && npm run build:cli",
    "tui": "npm run build:tui && node dist/tui/launcher.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "^0.56.0",
    "@hono/node-server": "^2.0.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opencode-ai/sdk": "^1.17.13",
    "@opentui/core": "^0.4.2",
    "better-sqlite3": "^12.11.1",
    "hono": "^4.12.27",
    "node-pty": "^1.1.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  }
}
